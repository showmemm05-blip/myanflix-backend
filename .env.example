DATABASE_URL=postgresql://user:password@localhost:5432/myanflix?schema=public

NODE_ENV=development
PORT=3001

JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

STORAGE_PATH=./storage

# Storage server (MinIO) — see ../storage-server. Credentials here must match
# MINIO_ROOT_USER/MINIO_ROOT_PASSWORD in storage-server/.env.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=myanflix
MINIO_SECRET_KEY=change-me-locally
MINIO_BUCKET=movies

# Cache server — see ../cacheserver. This is what end users' browsers
# actually fetch video bytes from, never this backend or MinIO directly.
STREAM_PUBLIC_BASE_URL=http://localhost:8080

# --- Only used by docker-compose.yml (backend/docker-compose.yml), not by
# plain `npm run start:dev` — it constructs DATABASE_URL itself from these.
POSTGRES_USER=myanflix
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=myanflix
POSTGRES_PORT=5432
